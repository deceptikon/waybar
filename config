  {
      "name": "bar-vert",
      "layer": "top",
      "position": "right",
      "width": 50,
      "fixed-center": true,
      "modules-left": [
        "clock",
        "sway/workspaces"
      ],
        "modules-center": [
          "battery",
          "custom/asus-profile",
          "custom/lang",
          "privacy"
        ],
"modules-right": [
            "idle_inhibitor",
            "power-profiles-daemon",
            "custom/dunst",
            "custom/recorder",
            "custom/checkupdates",
            "custom/fnlock",
            "custom/backlight"
            ],
       "include": [
         "/home/lexx/.config/waybar/default-modules-v2.json",
         "/home/lexx/.config/waybar/default-modules.json"
       ],
"custom/fnlock": {
           "exec": "~/.config/waybar/scripts/toggle_fn_lock.sh refresh",
           "return-type": "json",
           "signal": 10,
           "on-click": "/usr/local/bin/toggle_fn_lock.sh"
         },
       "custom/backlight": {
         "exec": "~/.config/waybar/scripts/zenbook-keylight/kbd_status_json.sh",
         "return-type": "json",
         "format": "{}",
         "format-icons": {
             "0": "󰛨",
             "1": "󰛩"
         },
         "on-click": "~/.config/waybar/scripts/zenbook-keylight/toggler.sh",
         "signal": 8
       }
     }
  ]
