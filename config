[
  {
    "name": "bar-low",
    "layer": "top",
    "position": "bottom",
    "height": 10,
    "background": "red",
    "modules-left": [
      "custom/uptime"
    ],
    "modules-right": [
      "custom/ollama"
    ],
    "modules-center": [
      "sway/mode"
    ],
    "include": [
      "/home/lexx/.config/waybar/default-modules-v2.json",
      "/home/lexx/.config/waybar/default-modules.json"
    ]
  },
  {
    "name": "bar-horiz",
    "layer": "top",
    "position": "top",
    "height": 25,
    "modules-left": [
      "custom/powerbtn",
      "group/temp-fan-group",
      "group/cpu-ram-group",
      "group/io-network-group",
      "group/network-combined"
    ],
    "modules-center": [
      "sway/window"
    ],
    "modules-right": [
      "group/audio",
      "group/bright",
      "group/network-bt"
    ],
    "include": [
      "/home/lexx/.config/waybar/default-modules-v2.json",
      "/home/lexx/.config/waybar/default-modules.json"
    ]
  },
  {
    "name": "bar-vert",
    "layer": "top",
    "position": "right",
    "width": 50,
    "fixed-center": true,
    "modules-left": [
      "clock",
      "sway/workspaces"
    ],
    "modules-center": [
      "battery",
      "custom/asus-profile",
      "custom/lang",
      "privacy"
    ],
    "modules-right": [
      "idle_inhibitor",
      "power-profiles-daemon",
      "custom/dunst",
      "custom/recorder",
      "custom/checkupdates",
      "custom/fnlock",
      "custom/backlight",
      "custom/ext-display"
    ],
    "include": [
      "/home/lexx/.config/waybar/default-modules-v2.json",
      "/home/lexx/.config/waybar/default-modules.json"
    ],
    "custom/fnlock": {
      "exec": "~/.config/waybar/scripts/toggle_fn_lock.sh refresh",
      "return-type": "json",
      "signal": 10,
      "on-click": "/usr/local/bin/toggle_fn_lock.sh"
    },
    "custom/backlight": {
      "exec": "~/.config/waybar/scripts/zenbook-keylight/kbd_status_json.sh",
      "return-type": "json",
      "format": "{}",
      "format-icons": {
        "0": "\udb81\udee8",
        "1": "\udb81\udee9"
      },
      "on-click": "~/.config/waybar/scripts/zenbook-keylight/toggler.sh",
      "signal": 8
    },
    "custom/ext-display": {
      "exec": "~/.config/waybar/scripts/toggle-ext-display.sh refresh",
      "return-type": "json",
      "format": "{}",
      "interval": 1000,
      "on-click": "swaymsg exec ~/.config/waybar/scripts/toggle-ext-display.sh",
      "signal": 11
    }
  }
]