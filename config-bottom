[
  {
    "name": "bar-bottom",
    "layer": "top",
    "position": "bottom",
    "reload_style_on_change": true,
    "height": 10,
    "fixed-center": true,
    "modules-right": [
      "sway/workspaces#bottom"
    ],
    "modules-center": [
      "tray"
    ],
    "modules-left": [
	"ext/workspaces"
    ],
    "include": [],
"ext/workspaces": {
	"format": "{name}: {icon}",
	"on-click": "activate",
	"format-icons": {
		"Workspace 1": "",
		"Workspace 2": "",
		"Workspace 3": "",
		"Workspace 4": "",
		"active": "",
		"default": ""
	},
	"sort-by-id": true
},
    "sway/workspaces#bottom": {
      "disable-scroll": false,
      "all-outputs": false,
      "format": "{icon} ",
      "active-only": true,
      "format-icons": {
        "0": "",
        "1": ": I",
        "2": ": II",
        "3": ": III",
        "4": ": IV",
        "5": ": V",
        "urgent": "",
        "active": "",
        "default": ""
      },
      "persistent-workspaces": {
        "0": [],
        "1": ["eDP-1", "HDMI-A-1"],
        "2": ["HDMI-A-1"],
      }
    },
    "tray": {
      "icon-size": 11,
      "spacing": 7,
      "icons": {
        "blueman": "bluetooth",
        "Telegram": "telegram"
      }
    }
  }
]
