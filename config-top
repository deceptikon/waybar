[
  {
    "name": "bar-top",
    "layer": "top",
    "position": "top",
    "modules-left": [
      "sway/workspaces"
    ],
    "modules-center": [
      "group/top-center"
    ],
    "modules-right": [
      "group/audio",
      "group/bright",
      "idle_inhibitor",
      "custom/keylight",
      "bluetooth#lite",
      "battery",
      "custom/powerbtn"
    ],
    "include": [
      "/home/lexx/.config/waybar/modules-hardware-group.json",
      "/home/lexx/.config/waybar/modules-ux-group.json"
    ],
    "group/top-center": {
      "orientation": "vertical",
      "modules": [
        "clock#date",
        "group/dynamic-row"
      ]
    },
    "group/dynamic-row": {
      "orientation": "horizontal",
      "modules": [
        "sway/mode",
        "group/titlebox"
      ]
    },
    "group/titlebox": {
      "orientation": "horizontal",
      "class": "titlebox-container",
      "modules": [
        "custom/ws-color",
        "clock#time",
        "sway/window",
        "custom/separator",
        "sway/scratchpad",
        "privacy"
      ]
    },
    "custom/penguin": {
      "format": "",
      "tooltip": false
    },
    "custom/ws-color": {
      "exec": "~/.config/waybar/scripts/ws-color.sh",
      "return-type": "json",
      "interval": "once",
      "signal": 8,
      "format": "{}",
      "tooltip": false
    },
    "custom/separator": {
      "format": "|",
      "tooltip": false
    },
    "clock#date": {
      "format": "<span text_transform=\"uppercase\">{:%A, %d %B %Y}</span>",
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "clock#time": {
      "format": "{:%H:%M}",
      "tooltip": false
    },
    "sway/workspaces": {
      "disable-scroll": false,
      "enable-bar-scroll": true,
      "disable-auto-back-and-forth": true,
      "smooth-scrolling-threshold": 20,
      "disable-scroll-wraparound": false,
      "format": ". {icon} <sub>{value}</sub> .",
      "format-icons": {
        "1": "\uf120",
        "2": "\uf268",
        "3": "\uf121",
        "4": "\uf1bc",
        "5": "\uf075",
        "focused": "\uf192",
        "urgent": "\uf06a",
        "active": "\uf192",
        "default": "\uf111"
      },
      "sort-by-number": true,
      "persistent_workspaces": {
        "1": [],
        "2": [],
        "3": [],
        "4": [],
        "5": []
      }
    },
    "sway/scratchpad": {
      "format": "{icon} {count}",
      "show-empty": false,
      "format-icons": [
        "",
        "\uf2d2"
      ],
      "tooltip": true,
      "tooltip-format": "{app}: {title}"
    },
    "sway/window": {
      "format": "\uf17c [{title}] {app_id}",
      "max-length": "",
      "all-outputs": true,
      "offscreen-css": true,
      "offscreen-css-text": "NO FOCUS",
      "icon-size": 16,
      "rewrite": {
        "(.*) Mozilla Firefox": "$1 \ud83c\udf0e",
        "(.*) VSCodium": "$1 \udb82\ude1e"
      }
    },
    "pulseaudio/slider": {
      "min": 0,
      "max": 90,
      "orientation": "horizontal",
      "format": "SUSU {}"
    },
    "backlight/slider": {
      "min": 9,
      "max": 100,
      "orientation": "horizontal",
      "device": "intel_backlight"
    },
    "output": [
      "eDP-1"
    ]
  },
