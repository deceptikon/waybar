{
  "layer": "top",
  "position": "right",
  "reload_style_on_change": true,
  "fixed-center": true,
"modules-center": [
      "group/vc-row1",
      "group/vc-row2"
    ],
    "group/vc-row1": {
      "orientation": "horizontal",
      "modules": ["custom/profile", "idle_inhibitor"]
    },
    "group/vc-row2": {
      "orientation": "horizontal",
      "modules": ["custom/dunst", "custom/ext-display"]
    },
    "modules-right": [
      "custom/ollama",
      "custom/llama",
      "custom/checkupdates",
      "custom/recorder",
      "custom/fnlock",
      "custom/powerbtn"
    ],
  "custom/checkupdates": {
    "exec": "~/.config/waybar/scripts/utils/checkupdates.sh",
    "return-type": "json",
    "interval": 3600,
    "format": "{}",
    "on-click": "wezterm -e yay -Syyu --noconfirm && yay -Sc --noconfirm && pkill -SIGRTMIN+8 waybar && notify-send 'Обновление завершено'",
    "signal": 8
  },
  "include": [
    "modules-vc.json"
  ]
}
