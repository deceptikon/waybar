{
  "layer": "top",
  "position": "right",
  "reload_style_on_change": true,
  "fixed-center": true,
"modules-center": [
      "group/vc-row1",
      "group/vc-row2"
    ],
    "group/vc-row1": {
      "orientation": "horizontal",
      "modules": ["power-profiles-daemon", "idle_inhibitor"]
    },
    "group/vc-row2": {
      "orientation": "horizontal",
      "modules": ["custom/dunst", "custom/ext-display"]
    },
    "modules-right": [
      "sway/workspaces#vert",
      "custom/ollama",
      "custom/llama",
      "custom/checkupdates",
      "custom/recorder",
      "custom/fnlock",
      "custom/powerbtn"
    ],
    // "sway/workspaces#vert": {
    //   "disable-scroll": false,
    //   "all-outputs": false,
    //   // "format": "{icon} ",
    //   // "active-only": true,
    //   "format-icons": {
    //     "0": "",
    //     "1": ": I",
    //     "2": ": II",
    //     "3": ": III",
    //     "4": ": IV",
    //     "5": ": V",
    //     "urgent": "",
    //     "active": "",
    //     "default": ""
    //   },
    //   "persistent-workspaces": {
    //     "0": [],
    //     "1": ["eDP-1", "HDMI-A-1"],
    //     "2": ["HDMI-A-1"]
    //   },
    //   "format": "<span size='larger'>{name}</span> {windows}",
    //    "format-window-separator": " | ",
    //    "window-rewrite-default": "{name}",
    //    "window-rewrite": {
    //      "title<*firefox>": "",
    //       "app_id<firefox>": "",
    //       "class<kitty>": "🖳",
    //       "app-id<.*ghostty>": "🖳",
    //       "app-id<foot>": "🦶",
    //       "title<.*youtube.*>": ""
    //    }
    // },
    "sway/workspaces": {
      "format": "<span size='larger'>{name}</span> {windows}",
      "format-window-separator": " | ",

      // КРИТИЧЕСКИЙ КОСТЫЛЬ ДЛЯ АКТИВАЦИИ REWRITE (Баг #3797)
      "window-format": "{value}",

      "window-rewrite-default": "🪟",
      "window-rewrite": {
        "firefox": "",
        "ghostty": "🖳",
        "zed": "📝",
        "thunar": "📁"
      }
    },
  "custom/checkupdates": {
    "exec": "~/.config/waybar/scripts/utils/checkupdates.sh",
    "return-type": "json",
    "interval": 3600,
    "format": "{}",
    "on-click": "wezterm -e yay -Syyu --noconfirm && yay -Sc --noconfirm && pkill -SIGRTMIN+8 waybar && notify-send 'Обновление завершено'",
    "signal": 8
  },
  "include": [
    "modules-vc.json"
  ]
}
