{
  "layer": "top",
  "position": "right",
  "reload_style_on_change": true,
  "fixed-center": true,
"modules-center": [
      "group/vc-row1",
      "group/vc-row2"
    ],
    "group/vc-row1": {
      "orientation": "horizontal",
      "modules": ["custom/profile", "idle_inhibitor"]
    },
    "group/vc-row2": {
      "orientation": "horizontal",
      "modules": ["custom/dunst", "custom/ext-display"]
    },
    "modules-right": [
      "custom/ollama",
      "custom/llama",
      "custom/checkupdates",
      "power-profiles-daemon",
      "custom/recorder",
      "custom/fnlock",
      "custom/powerbtn"
    ],
  "include": [
    "modules-controls.json"
  ]
}
