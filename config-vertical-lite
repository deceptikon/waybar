[
  {
    "name": "bar-vert-lite",
    "layer": "top",
    "position": "right",
    "start_hidden": true,
    "reload_style_on_change": true,
    "width": 69,
    "fixed-center": true,
    "modules-left": [
      "custom/compact-gpu",
      "custom/compact-cpu",
      "custom/compact-ram",
      "custom/compact-ssd"
    ],
    "modules-center": [
      "custom/lang",
      "idle_inhibitor"
    ],
    "modules-right": [
      "custom/dunst",
      "custom/recorder",
      "custom/fnlock"
    ],
    "include": [
      "modules-controls.json"
    ],
    "custom/lang": {
      "exec": "swaymsg -t get_inputs | grep layout_name | grep -v En | awk 'END{if(NR == 0){print \"EN\"}else{print toupper(substr($2,2,2))}}'",
      "interval": 1,
      "format": "{}"
    },
    "custom/compact-gpu": {
      "exec": "~/.config/waybar/scripts/sysmon/compact-gpu.py",
      "interval": 2,
      "format": "{}",
      "return-type": "json"
    },
    "custom/compact-cpu": {
      "exec": "~/.config/waybar/scripts/sysmon/compact-cpu.py",
      "interval": 2,
      "format": "{}",
      "return-type": "json"
    },
    "custom/compact-ram": {
      "exec": "~/.config/waybar/scripts/sysmon/compact-ram.py",
      "interval": 2,
      "format": "{}",
      "return-type": "json"
    },
    "custom/compact-ssd": {
      "exec": "~/.config/waybar/scripts/sysmon/compact-ssd.py",
      "interval": 2,
      "format": "{}",
      "return-type": "json"
    }
  }
]
