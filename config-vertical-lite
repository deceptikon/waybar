[
  {
    "name": "bar-vert-lite",
    "layer": "top",
    "position": "right",
    "start_hidden": true,
    "reload_style_on_change": true,
    "width": 69,
    "fixed-center": true,
    "modules-left": [
      "custom/compact-gpu",
      "custom/compact-cpu",
      "custom/compact-ram",
      "custom/compact-ssd"
    ],
    "modules-center": [
      "custom/lang",
      "idle_inhibitor"
    ],
    "modules-right": [
      "custom/dunst",
      "custom/recorder",
      "custom/fnlock"
    ],
    "include": [
      "modules-controls.json",
      "modules-compact.json"
    ],
    "custom/lang": {
      "exec": "swaymsg -t get_inputs | grep layout_name | grep -v En | awk 'END{if(NR == 0){print \"EN\"}else{print toupper(substr($2,2,2))}}'",
      "interval": 1,
      "format": "{}"
    }
  }
]
