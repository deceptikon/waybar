{
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "",
      "performance": "",
      "balanced": "",
      "power-saver": ""
    }
  },
  "power-profiles-daemon#sidebar": {
    "format": "{icon} {profile}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "",
      "performance": "",
      "balanced": "",
      "power-saver": ""
    },
    "on-click": "busctl --user call net.hadess.PowerProfiles /net/hadess/PowerProfiles net.hadess.PowerProfiles SetProfile s $(case \"$(busctl --user get-property net.hadess.PowerProfiles /net/hadess/PowerProfiles net.hadess.PowerProfiles ActiveProfile | awk '{print $2}')\" in performance) echo balanced ;; balanced) echo power-saver ;; *) echo performance ;; esac)"
  },
  "group/battery-state": {
    "orientation": "vertical",
    "modules": ["battery", "custom/battery-info", "custom/acpi-detailed"]
  },
  "group/language": {
    "orientation": "vertical",
    "modules": ["custom/lang"]
  },
  "group/switches": {
    "orientation": "vertical",
    "modules": [
      "idle_inhibitor",
      "power-profiles-daemon",
      "custom/dunst",
      "custom/recorder",
      "custom/kbd-auto",
      "custom/checkupdates"
    ]
  },
  "group/power-off": {
    "orientation": "horizontal",
    "modules": ["custom/powerbtn"]
  },
  "group/uptime-mode": {
    "id": "uptime-mode",
    "orientation": "horizontal",
    "modules": [
      "sway/mode",
      "tray#lite"
    ]
  },
  "group/title-mode": {
    "id": "title-mode",
    "orientation": "vertical",
    "modules": [
      "group/uptime-mode",
      "sway/window"
    ]
  },
  "group/audio": {
    "orientation": "horizontal",
    "modules": ["pulseaudio", "pulseaudio/slider"]
  },
  "group/bright": {
    "orientation": "horizontal",
    "modules": ["backlight", "backlight/slider"]
  },
  "group/network": {
    "orientation": "horizontal",
    "modules": ["network", "bluetooth"]
  },
  "custom/uptime": {
    "exec": "uptime -p | sed 's/up //'",
    "interval": 60,
    "format": "󱎫 {}"
  },
  "clock": {
    "format": " {:%H:%M\n%d.%m.%y}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  "sway/workspaces": {
    "format": "{icon} <sub>{value}</sub>",
    "format-icons": {
      "1": "",
      "2": "",
      "3": "",
      "4": "",
      "5": "",
      "focused": "",
      "default": ""
    }
  }
}
