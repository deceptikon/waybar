      "interval": 2,
      "format": "{}",
      "return-type": "json"
   },
   "custom/io-indicator-vertical": {
      "exec": "~/.config/waybar/scripts/io-indicator-vertical.sh",
      "interval": 2,
      "format": "{}",
      "return-type": "json"
   },
   "custom/network-indicator-vertical": {
      "exec": "~/.config/waybar/scripts/network-indicator-vertical.sh",
      "interval": 2,
      "format": "{}",
      "return-type": "json"
   },
    "group/vertical-indicators": {
       "orientation": "vertical",
       "modules": [
         "custom/cpu-indicator-vertical",
         "custom/ram-indicator-vertical",
         "custom/io-indicator-vertical",
         "custom/network-indicator-vertical"
       ]
    },
    "group/cpu-ram-group": {
