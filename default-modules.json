{
  "group/switches": {
    "orientation": "horizontal",
    "drawer": { "transition-duration": 500, "transition-left-to-right": false },
    "modules": ["group/base-switches", "bluetooth", "network"]
  },
  "group/base-switches": {
    "orientation": "horizontal",
    "modules": ["bluetooth#lite", "network#lite"]
  },
  "group/hardware": {
    "orientation": "horizontal",
    "drawer": { "transition-duration": 500, "transition-left-to-right": true },
    "modules": ["group/subcpu", "memory", "custom/disk-io", "load"]
  },
  "group/temp-group": {
    "orientation": "horizontal",
    "drawer": { "transition-duration": 500, "transition-left-to-right": true },
    "modules": [
      "group/temperatura",
      "custom/fan",
      "custom/fan2",
      "custom/temp-detailed"
    ]
  },
  "group/temperatura": {
    "orientation": "horizontal",
    "modules": ["temperature", "custom/fanlabel"]
  },
  "group/power": {
    "orientation": "horizontal",
    "modules": ["battery", "custom/asus-profile"]
  },
  "group/bat-group": {
    "orientation": "vertical",
    "drawer": { "transition-duration": 500, "transition-left-to-right": false },
    "modules": [
      "group/power",
      "custom/battery-info",
      "custom/acpi-detailed",
      "custom/power-draw"
    ]
  },

  "group/subcpu": {
    "orientation": "horizontal",
    "modules": ["cpu", "custom/ram"]
  },
  "cpu": { "format": " Ôčõ <sub>CPU</sub> {usage}% ", "interval": 2 },
  "custom/ram": { "format": "  ÔĒł {} " },
  "custom/fanlabel": { "format": "  Ô°£ " },
  "memory": {
    "interval": 30,
    "format": "free:{avail:0.1f}G used:{used:0.1f}G   "
  },
  "custom/disk-io": {
    "exec": "iostat -d 1 2 | grep '^nvme' | tail -n 1 | awk '{printf \" ‚Üď%.1f ‚ÜĎ%.1f MB/s (IOPS: %d)\", $3/1024, $4/1024, $2}'",
    "interval": 2,
    "format": " ůįčä <sub>SSD:</sub> {}"
  },
  "temperature": {
    "hwmon-path": "/sys/class/hwmon/hwmon6/temp1_input",
    "critical-threshold": 85,
    "format": " {icon} {temperatureC}¬įC ",
    "format-icons": ["Ôčč", "ÔčČ", "Ôčá"]
  },
  "custom/fan": {
    "exec": "cat /sys/class/hwmon/hwmon8/fan1_input",
    "format": "{}<sub>RPM</sub> ",
    "interval": 5
  },
  "custom/fan2": {
    "exec": "cat /sys/class/hwmon/hwmon8/fan2_input",
    "format": ": ůįąź {}<sub>RPM</sub> ",
    "interval": 5
  },
   "custom/ollama": {
     "exec": "if curl -s http://localhost:11111/api/tags > /dev/null 2>&1; then models=$(OLLAMA_HOST=localhost:11111 ollama ps 2>/dev/null | awk 'NR>1 {print $1}' | paste -sd ' ' -); if [ -n \"$models\" ]; then jq -n --arg m \"$models\" --compact-output '{text:(\"ůĪö£ \" + $m),tooltip:(\"Running: \" + $m),class:\"on\"}'; else jq -n --compact-output '{text:\"ůĪö£ UP\",tooltip:\"Ollama is running (no models loaded)\",class:\"on\"}'; fi; else jq -n --compact-output '{text:\"ůĪö£ DOWN\",tooltip:\"Ollama is not running\",class:\"off\"}'; fi",
     "interval": 5,
     "format": "{}",
     "return-type": "json"
   },
  "custom/temp-detailed": {
    "exec": "sensors | awk '/amdgpu/{c=\"G\"} /nvme/{c=\"S\"} /mt7921/{c=\"W\"} /acpitz/{c=\"M\"} /edge|Composite|temp1|temp2/{split($2,a,/[+¬į]/); v=a[2]; if(c==\"G\")gpu=v; if(c==\"S\")ssd=v; if(c==\"W\")wf=v; if(c==\"M\"&&/temp1/)m1=v; if(c==\"M\"&&/temp2/)m2=v} END {printf \"ůįĘģ %s¬į ůįčä %s¬į ůįĖ∂ %s¬į ůįüÄ %s/%s¬į\\n\", gpu, ssd, wf, m1, m2}'",
    "interval": 5,
    "format": " {} "
  },
  "battery": {
    "bat": "BAT0",
    "interval": 20,
    "full-at": 90,
    "states": {
      "good": 50,
      "warning": 10,
      "critical": 5
    },
    "design-capacity": false,
    "format-time": "{H}:{M}",
    "format-good": " {icon}<small> {capacity}%</small>",
    "format-warning": " {icon}<small> {capacity}%</small>",
    "format-critical": " {icon}<small> {capacity}% LOW CHARGE! (off in {time})</small> ",
    "format": " {icon} ",
    "format-charging": " Ôá¶ {icon} ",
    "format-icons": {
      "default": ["ůįāé", "ůįĀļ", "ůįĀĽ", "ůįĀľ", "ůįĀĹ", "ůįĀĺ", "ůįĀŅ", "ůįāÄ", "ůįāĀ", "ůįāā", "ůįĀĻ"],
      "charging": ["ůįĘü", "ůįĘú", "ůįāÜ", "ůįāá", "ůįāą", "ůįĘĚ", "ůįāČ", "ůįĘě", "ůįāä", "ůįāč", "ůįāÖ"]
    },
    "tooltip-format": "Time remaining: {time}\nCycles: {cycles}\nPower draw: {power}W",
    "tooltip-format-charging": "Time to full: {time}\nCycles: {cycles}\nPower draw: {power}W"
  },
  "custom/battery-info": {
    "exec": "upower -i /org/freedesktop/UPower/devices/battery_BAT0 | awk '/state:/ {s=$2} /energy-full:/ {ef=$2} /energy-rate:/ {er=$2} /voltage:/ {v=$2} /percentage:/ {p=$2} /time to (empty|full):/ {t=$(NF-1) \" \" $NF} END {mah=int((ef/v)*1000); printf \"{\\\"text\\\":\\\"%s ůĪéę %s | Ôóü %sW | ůĪźĆ %sV | ÔĀÉ %smAh \\\"}\\n\", p, t, er, v, mah}'",
    "return-type": "json",
    "interval": 20,
    "format": " {}"
  },
  "custom/acpi-detailed": {
    "exec": "acpi -b | awk '{print $3, $4, $5}'",
    "interval": 10,
    "format": "ůįö• {}"
  },
  "custom/power-draw": {
    "exec": "awk '{printf \"%.1f W\", $1/1000000}' /sys/class/power_supply/BAT0/power_now",
    "interval": 5,
    "format": "ÔÉß {}"
  },
  "custom/asus-profile": {
    "exec": "asusctl profile get | awk '/Active profile/ {p=$NF; icon=(p==\"Quiet\"?\"ÔĀ¨ ECO\":(p==\"Balanced\"?\"ÔČé  BAL\":\"Ôė• PERF\")); print icon}'",
    "interval": 2,
    "format": " {} ",
    "on-click": "asusctl profile next && pkill -SIGRTMIN+10 waybar",
    "signal": 10,
    "rewrite": {
      "Quiet": "Quiet ÔĀ¨",
      "Balanced": "Bal ÔČé",
      "Performance": "Perf Ôė•"
    }
  },
  "network": {
    "format-wifi": " Ôáę {essid} ",
    "format": "ůįąÄ {ifname}",
    "format-disconnected": "‚ö† Disconnected"
  },
  "network#lite": {
    "format-wifi": " Ôáę <sub>({signalStrength}%)</sub> ",
    "format": " ůįąÄ {ifname}",
    "format-disconnected": " ůįĆô DOWN"
  },
  "bluetooth#lite": {
    "format": " {icon} ",
    "format-icons": { "enabled": "Ôäď", "disabled": "ůįā≤" },
    "on-click": "blueman-manager",
    "format-connected": "ÔäĒ {device_alias}",
    "format-connected-battery": "ÔäĒ {device_alias} {device_battery_percentage}%",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%"
  },
  "bluetooth": {
    "format": " {icon} {status}",
    "format-icons": { "enabled": "ůįāĮ", "disabled": "ůįā≤" },
    "on-click": "blueman-manager",
    "format-connected": "ÔäĒ {device_alias}",
    "format-connected-battery": "ÔäĒ {device_alias} {device_battery_percentage}%",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%"
  },
  "group/audio": {
    "orientation": "horizontal",
    "modules": ["pulseaudio", "pulseaudio/slider"]
  },
  "group/bright": {
    "orientation": "horizontal",
    "modules": ["backlight", "backlight/slider"]
  },
  "pulseaudio": {
    "format": " {icon}",
    "format-muted": " Ó¨§",
    "format-icons": {
      "alsa_output.pci-0000_00_1f.3.analog-stereo": "ÓĆ≠",
      "alsa_output.pci-0000_00_1f.3.analog-stereo-muted": "ÓĽ®ÓĆ≠",
      "headphone": "ÔÄ•",
      "hands-free": "ÔĖź",
      "headset": "ÔĖź",
      "phone": "Ôāē",
      "phone-muted": "Óīó",
      "portable": "Ôāē",
      "car": "ÔÜĻ",
      "default": ["ÔÄ¶", "ÔÄß", "ÔÄ®"]
    },
    "on-click": "amixer -q sset Master toggle",
    "scroll-step": 1,
    "on-right-click": "pavucontrol"
  },
  "pulseaudio/slider": {
    "min": 0,
    "max": 90,
    "orientation": "horizontal",
    "format": "SUSU {}"
  },
  "backlight": { "format": " ůįÉü" },
  "backlight/slider": {
    "min": 9,
    "max": 100,
    "orientation": "horizontal",
    "device": "intel_backlight"
  },
  "sway/window": {
    "format": "ÔÖľ [{title}] {app_id}",
    "max-length": "",
    "all-outputs": true,
    "offscreen-css": true,
    "offscreen-css-text": "–°–ź–°–Į–ú–Ď–ź",
    "icon-size": 48,
    "rewrite": { "(.*) Mozilla Firefox": "$1 ūüĆé", "(.*) VSCodium": "$1 ůį®ě" }
  },
  "mpris#cassette": {
    "format": " ůįßĒ <small>{status_icon}</small> {position}",
    "status-icons": { "paused": "Ó¨¨", "stopped": "Ó¨¨", "playing": "ÓęĎ" },
    "dynamic-len": 25
  },
  "group/music": {
    "orientation": "horizontal",
    "modules": ["mpris#cassette","mpris"],
    "drawer": { "transition-duration": 500, "transition-left-to-right": true }
  },
  "mpris": {
    "format": " {status_icon} {dynamic}‚ôę  ",
    "dynamic-len": 25,
    "player-icons": { "default": "Ó¨¨", "mpv": "ūüéĶ" },
    "status-icons": { "paused": "Ó¨¨", "stopped": "Ó¨¨", "playing": "ÓęĎ" }
  },
  "sway/workspaces": {
    "disable-scroll": false,
    "enable-bar-scroll": true,
    "disable-auto-back-and-forth": true,
    "smooth-scrolling-threshold": 20,
    "disable-scroll-wraparound": false,
    "format": ". {icon} <sub>{value}</sub> .",
    "format-icons": {
      "1": "ÔĄ†",
      "2": "ÔČ®",
      "3": "ÔĄ°",
      "4": "ÔÜľ",
      "5": "ÔĀĶ",
      "focused": "ÔÜí",
      "urgent": "ÔĀ™",
      "active": "ÔÜí",
      "default": "ÔĄĎ"
    },
    "sort-by-number": true,
    "persistent_workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },
  "custom/recorder": {
    "format": "{}",
    "interval": "once",
    "return-type": "json",
    "exec": "echo \"$(pgrep -x wf-recorder > /dev/null && echo '{\"text\":\"ůį®ú <sup>ůįĎä</sup>\",\"class\":\"recording\"}' || echo '{\"text\":\"ůį®ú <sup>Óģß</sup>\",\"class\":\"stopped\"}')\"",
    "signal": 8,
    "on-click": "~/.config/waybar/scripts/capturer.sh",
    "on-right-click": "kill $(pgrep -x wf-recorder)",
    "tooltip": false
  },
  "custom/checkupdates": {
    "exec": "~/.config/waybar/scripts/checkupdates.sh",
    "return-type": "json",
    "interval": 3600,
    "format": "{}",
    "on-click": "wezterm -e paru -Syyu --noconfirm && paru -Sc --noconfirm && pkill -SIGRTMIN+8 waybar && notify-send '–ě–Ī–Ĺ–ĺ–≤–Ľ–Ķ–Ĺ–ł–Ķ –∑–į–≤–Ķ—Ä—ą–Ķ–Ĺ–ĺ'",
    "signal": 8
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "Óįē <sup>ůįí≥</sup>",
      "deactivated": "ůįĺ™ <sup>ůįí≤</sup>"
    }
  },
  "custom/vpnOFF": {
    "format": "ÔŹ≠",
    "on-click": "~/.config/waybar/scripts/toggle-vpn.sh && pkill -SIGRTMIN+3 waybar",
    "exec": "~/.config/waybar/scripts/toggle-vpn.sh refresh",
    "return-type": "json",
    "interval": 5,
    "signal": 3
  },
  "custom/lang": {
    "exec": "swaymsg -t get_inputs | grep layout_name | grep -v En | awk 'END{if(NR == 0){print \"EN\"}else{print toupper(substr($2,2,2))}}'",
    "interval": 1,
    "format": "{}"
  },
  "custom/dunst": {
    "exec": "~/.config/waybar/scripts/toggleDunst.sh refresh",
    "return-type": "json",
    "interval": 1000,
    "format": "{}",
    "on-click": "~/.config/waybar/scripts/toggleDunst.sh",
    "signal": 9
  },
  "custom/powerbtn": {
    "exec": "echo \"{\\\"text\\\":\\\"ůįź•\\\",\\\"tooltip\\\":\\\"$(uptime)\\\"}\"",
    "interval": 60,
    "format": "{}",
    "tooltip": "true",
    "return-type": "json",
    "on-click": "exec ~/.config/waybar/scripts/shutdown-dmenu.sh"
  },
  "tray": {
    "icon-size": 20,
    "spacing": 10
  },
  "tray#lite": {
    "icon-size": 13,
    "spacing": 6
  },
  "clock": {
    "format": "ÔÄó {:%H:%M\n%d.%m.%y}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "on-click": "yad --name=yad-calendar --calendar --undecorated",
    "actions": {
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "group/title": {
    "orientation": "vertical",
    "modules": ["sway/mode", "privacy"]
  },
   "privacy": {
     "icon-spacing": 4,
     "icon-size": 18,
     "transition-duration": 250,
     "modules": [
       {
         "type": "screenshare",
         "tooltip": true,
         "tooltip-icon-size": 24
       },
       {
         "type": "audio-out",
         "tooltip": true,
         "tooltip-icon-size": 24
       },
       {
         "type": "audio-in",
         "tooltip": true,
         "tooltip-icon-size": 24
       }
     ],
     "ignore-monitor": true,
     "ignore": [
       {
         "type": "audio-in",
         "name": "cava"
       },
       {
         "type": "screenshare",
         "name": "obs"
       }
     ]
   },
   "custom/cpu-indicator": {
