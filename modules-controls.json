{
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": " <sup>󰒳</sup>",
      "deactivated": "󰾪 <sup>󰒲</sup>"
    }
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "",
      "performance": "",
      "balanced": "",
      "power-saver": ""
    }
  },
  "custom/dunst": {
    "exec": "~/.config/waybar/scripts/utils/dunst.sh refresh",
    "return-type": "json",
    "interval": 1000,
    "format": "{}<sup></sup>",
    "on-click": "~/.config/waybar/scripts/utils/dunst.sh",
    "signal": 9
  },
  "custom/recorder": {
    "format": "{}",
    "interval": "once",
    "return-type": "json",
    "exec": "echo \"$(pgrep -x wf-recorder > /dev/null && echo '{\"text\":\"󰨜 <sup>󰑊</sup>\",\"class\":\"recording\"}' || echo '{\"text\":\"󰨜 <sup></sup>\",\"class\":\"stopped\"}')\"",
    "signal": 8,
    "on-click": "~/.config/waybar/scripts/utils/capturer.sh",
    "on-right-click": "kill $(pgrep -x wf-recorder)",
    "tooltip": false
  },
  "custom/checkupdates": {
    "exec": "~/.config/waybar/scripts/utils/checkupdates.sh",
    "return-type": "json",
    "interval": 3600,
    "format": "{}",
    "on-click": "wezterm -e yay -Syyu --noconfirm && yay -Sc --noconfirm && pkill -SIGRTMIN+8 waybar && notify-send 'Обновление завершено'",
    "signal": 8
  },
  "custom/fnlock": {
    "exec": "~/.config/waybar/scripts/utils/fn-lock.sh refresh",
    "return-type": "json",
    "signal": 10,
    "on-click": "/usr/local/bin/toggle_fn_lock.sh"
  },
  "custom/ext-display": {
    "exec": "~/.config/waybar/scripts/utils/ext-display.sh refresh",
    "return-type": "json",
    "format": "{}",
    "interval": 1000,
    "on-click": "~/.config/waybar/scripts/utils/ext-display.sh",
    "signal": 11
  },
  "custom/llama": {
    "exec": "~/.config/waybar/scripts/utils/llama-server.sh",
    "return-type": "json",
    "format": "{}",
    "interval": 5,
    "signal": 22,
    "on-click": "~/.config/waybar/scripts/utils/llama-server.sh toggle"
  },
  "custom/ollama": {
    "exec": "if curl -s http://localhost:11111/api/tags > /dev/null 2>&1; then models=$(OLLAMA_HOST=localhost:11111 ollama ps 2>/dev/null | awk 'NR>1 {print $1}' | paste -sd ' ' -); if [ -n \"$models\" ]; then jq -cn --arg m \"$models\" '{text:(\"󱚣 \" + $m),tooltip:(\"Running: \" + $m),class:\"on\"}'; else jq -cn '{text:\"󱚣 UP\",tooltip:\"Ollama is running (no models loaded)\",class:\"on\"}'; fi; else jq -cn '{text:\"󱚣 DOWN\",tooltip:\"Ollama is not running\",class:\"off\"}'; fi",
    "interval": 5,
    "format": "{}",
    "return-type": "json"
  },
  "custom/profile": {
    "exec": "tail -F ~/.config/waybar/feeds/asus.json 2>/dev/null",
    "return-type": "json",
    "format": "{}",
    "on-click": "asusctl profile next && pkill -SIGRTMIN+10 waybar"
  },
  "custom/toggle-vert-lite": {
    "format": "󰨞",
    "tooltip": false,
    "on-click": "/home/lexx/.config/waybar/scripts/utils/toggle-vert-lite.sh",
    "interval": 86400
  }
}