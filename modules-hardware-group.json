{
  "group/ddc": {
    "orientation": "horizontal",
    "modules": [
      "custom/ddc-brightness-icon",
      "custom/ddc-brightness",
      "custom/ddc-contrast-icon",
      "custom/ddc-contrast"
    ]
  },
  "custom/ddc-brightness-icon": {
    "format": "󰃠",
    "tooltip": false,
    "on-scroll-up": "~/.config/waybar/scripts/ddc.sh brightness up && pkill -SIGRTMIN+11 waybar",
    "on-scroll-down": "~/.config/waybar/scripts/ddc.sh brightness down && pkill -SIGRTMIN+11 waybar"
  },
  "custom/ddc-contrast-icon": {
    "format": "󰆈",
    "tooltip": false,
    "on-scroll-up": "~/.config/waybar/scripts/ddc.sh contrast up && pkill -SIGRTMIN+12 waybar",
    "on-scroll-down": "~/.config/waybar/scripts/ddc.sh contrast down && pkill -SIGRTMIN+12 waybar"
  },
  "custom/ddc-brightness": {
    "exec": "~/.config/waybar/scripts/ddc.sh brightness get",
    "interval": 120,
    "format": "{}",
    "return-type": "json",
    "on-scroll-up": "~/.config/waybar/scripts/ddc.sh brightness up && pkill -SIGRTMIN+11 waybar",
    "on-scroll-down": "~/.config/waybar/scripts/ddc.sh brightness down && pkill -SIGRTMIN+11 waybar",
    "signal": 11
  },
  "custom/ddc-contrast": {
    "exec": "~/.config/waybar/scripts/ddc.sh contrast get",
    "interval": 120,
    "format": "{}",
    "return-type": "json",
    "on-scroll-up": "~/.config/waybar/scripts/ddc.sh contrast up && pkill -SIGRTMIN+12 waybar",
    "on-scroll-down": "~/.config/waybar/scripts/ddc.sh contrast down && pkill -SIGRTMIN+12 waybar",
    "signal": 12
  },
  "custom/keylight": {
    "exec": "~/.config/waybar/scripts/utils/keylight/kbd_status_json.sh",
    "return-type": "json",
    "format": "{}",
    "on-click": "~/.config/waybar/scripts/utils/keylight/toggler.sh",
    "signal": 8
  },
  "group/audio": {
    "orientation": "horizontal",
    "modules": ["pulseaudio", "pulseaudio/slider"]
  },
  "group/bright": {
    "orientation": "horizontal",
    "modules": ["backlight", "backlight/slider"]
  },
  "pulseaudio": {
    "format": " {icon}",
    "format-muted": " \ueb24",
    "format-icons": {
      "alsa_output.pci-0000_00_1f.3.analog-stereo": "\ue32d",
      "alsa_output.pci-0000_00_1f.3.analog-stereo-muted": "\ueee8\ue32d",
      "headphone": "\uf025",
      "hands-free": "\uf590",
      "headset": "\uf590",
      "phone": "\uf095",
      "phone-muted": "\ued17",
      "portable": "\uf095",
      "car": "\uf1b9",
      "default": ["\uf026", "\uf027", "\uf028"]
    },
    "on-click": "amixer -q sset Master toggle",
    "scroll-step": 1,
    "on-right-click": "pavucontrol"
  },
  "pulseaudio/slider": {
    "min": 0,
    "max": 90,
    "orientation": "horizontal",
    "format": "SUSU {}"
  },
  "backlight": {
    "format": " \udb80\udcdf"
  },
  "backlight/slider": {
    "min": 9,
    "max": 100,
    "orientation": "horizontal",
    "device": "intel_backlight"
  },
  "battery": {
    "bat": "BAT0",
    "interval": 20,
    "full-at": 90,
    "states": {
      "good": 50,
      "warning": 10,
      "critical": 5
    },
    "design-capacity": false,
    "format-time": "{H}:{M}",
    "format-good": " {icon}<small> {capacity}%</small>",
    "format-warning": " {icon}<small> {capacity}%</small>",
    "format-critical": " {icon}<small> {capacity}% LOW CHARGE! (off in {time})</small> ",
    "format": " {icon} ",
    "format-charging": " \uf1e6 {icon} ",
    "format-icons": {
      "default": [
        "\udb80\udc8e",
        "\udb80\udc7a",
        "\udb80\udc7b",
        "\udb80\udc7c",
        "\udb80\udc7d",
        "\udb80\udc7e",
        "\udb80\udc7f",
        "\udb80\udc80",
        "\udb80\udc81",
        "\udb80\udc82",
        "\udb80\udc79"
      ],
      "charging": [
        "\udb82\udc9f",
        "\udb82\udc9c",
        "\udb80\udc86",
        "\udb80\udc87",
        "\udb80\udc88",
        "\udb82\udc9d",
        "\udb80\udc89",
        "\udb82\udc9e",
        "\udb80\udc8a",
        "\udb80\udc8b",
        "\udb80\udc85"
      ]
    },
    "tooltip-format": "Time remaining: {time}\nCycles: {cycles}\nPower draw: {power}W",
    "tooltip-format-charging": "Time to full: {time}\nCycles: {cycles}\nPower draw: {power}W"
  },
  "network": {
    "format-wifi": " \uf1eb {essid} ",
    "format": "\udb80\ude00 {ifname}",
    "format-disconnected": "\u26a0 Disconnected"
  },
  "network#lite": {
    "format-wifi": " \uf1eb <sub>({signalStrength}%)</sub> ",
    "format": " \udb80\ude00 {ifname}",
    "format-disconnected": " \udb80\udf19 DOWN"
  },
  "bluetooth#lite": {
    "format": " {icon} ",
    "format-icons": {
      "enabled": "\uf293",
      "disabled": "\udb80\udcb2"
    },
    "on-click": "~/.config/waybar/scripts/utils/bt-toggle.sh",
    "on-click-right": "blueman-manager",
    "format-connected": "\uf294",
    "format-connected-battery": "\uf294<sub>{device_battery_percentage}%</sub>",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%"
  },
  "bluetooth": {
    "format": " {icon} {status}",
    "format-icons": {
      "enabled": "\udb80\udcaf",
      "disabled": "\udb80\udcb2"
    },
    "on-click": "rfkill toggle bluetooth",
    "on-click-right": "blueman-manager",
    "format-connected": "\uf294 {device_alias}",
    "format-connected-battery": "\uf294 {device_alias} {device_battery_percentage}%",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%"
  },
  "custom/bt-indicator": {
    "exec": "~/.config/waybar/scripts/utils/bt-indicator.sh",
    "interval": 5,
    "format": "{}",
    "return-type": "json",
    "on-click": "blueman-manager"
  },
  "custom/powerbtn": {
    "exec": "echo \"{\\\"text\\\":\\\"\uf011\\\",\\\"tooltip\\\":\\\"$(uptime)\\\"}\"",
    "interval": 60,
    "format": "{}",
    "tooltip": "true",
    "return-type": "json",
    "on-click": "exec ~/.config/waybar/scripts/utils/shutdown-dmenu.sh"
  }
}
