{
  "network#qwi": {
    "format": "  ",
    "tooltip-format": "{ifname} via {gwaddr} 󰊗",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) ",
    "tooltip-format-ethernet": "{ifname} ",
    "tooltip-format-disconnected": "Disconnected",
    "format-icons": [
      "\udb80\udf5f",
      "\udb80\udf62",
      "\udb80\udf65",
      "\udb80\udf68",
      "\udb80\udf6b",
      "\udb80\udf6e"
    ]
  },
  "group/qwen-network": {
    "orientation": "horizontal",
    "modules": [
      "network#qwi",
      "custom/qwen-wifi-info"
    ]
  },
  "custom/qwen-wifi-info": {
    "exec": "~/.config/waybar/scripts/network/wifi-info.sh",
    "interval": 2,
    "format": "{}",
    "return-type": "json",
    "justify": "center",
    "align": 0.5,
    "on-click": "nm-connection-editor",
    "on-right-click": "nm-applet --indicator"
  },
  "custom/qwen-gpu-icon": {
    "exec": "~/.config/waybar/scripts/sysmon/icon.sh gpu",
    "interval": "once",
    "format": "{}",
    "return-type": "json"
  },
  "group/qwen-gpu": {
    "orientation": "horizontal",
    "modules": [
      "custom/qwen-gpu-icon",
      "custom/qwen-gpu"
    ]
  },
  "custom/qwen-gpu": {
    "exec": "tail -F ~/.config/waybar/feeds/gpu.json 2>/dev/null",
    "format": "{}",
    "return-type": "json",
    "justify": "center",
    "align": 0.5,
    "on-click": "gpustat",
    "on-right-click": "nvtop"
  },
  "custom/qwen-cpu-icon": {
    "exec": "~/.config/waybar/scripts/sysmon/icon.sh cpu",
    "interval": "once",
    "format": "{}",
    "return-type": "json"
  },
  "group/qwen-cpu": {
    "orientation": "horizontal",
    "modules": [
      "custom/qwen-cpu-icon",
      "custom/qwen-cpu"
    ]
  },
  "custom/qwen-cpu": {
    "exec": "tail -F ~/.config/waybar/feeds/cpu.json 2>/dev/null",
    "format": "{}",
    "return-type": "json",
    "justify": "center",
    "align": 0.5,
    "on-click": "htop",
    "on-right-click": "gnome-system-monitor"
  },
  "custom/qwen-ram-icon": {
    "exec": "~/.config/waybar/scripts/sysmon/icon.sh ram",
    "interval": "once",
    "format": "{}",
    "return-type": "json"
  },
  "group/qwen-ram": {
    "orientation": "horizontal",
    "modules": [
      "custom/qwen-ram-icon",
      "custom/qwen-ram"
    ]
  },
  "custom/qwen-ram": {
    "exec": "tail -F ~/.config/waybar/feeds/ram.json 2>/dev/null",
    "format": "{}",
    "return-type": "json",
    "justify": "center",
    "align": 0.5,
    "on-click": "gnome-system-monitor",
    "on-right-click": "free -h"
  },
  "custom/qwen-ssd-icon": {
    "exec": "~/.config/waybar/scripts/sysmon/icon.sh ssd",
    "interval": "once",
    "format": "{}",
    "return-type": "json"
  },
  "group/qwen-ssd": {
    "orientation": "horizontal",
    "modules": [
      "custom/qwen-ssd-icon",
      "custom/qwen-ssd"
    ]
  },
  "custom/qwen-ssd": {
    "exec": "tail -F ~/.config/waybar/feeds/ssd.json 2>/dev/null",
    "format": "{}",
    "return-type": "json",
    "justify": "center",
    "align": 0.5,
    "on-click": "gnome-disks",
    "on-right-click": "lsblk"
  },
  "custom/qwen-temp-icon": {
    "exec": "~/.config/waybar/scripts/sysmon/icon.sh temp",
    "interval": "once",
    "format": "{}",
    "return-type": "json"
  },
  "group/qwen-temp": {
    "orientation": "horizontal",
    "modules": [
      "custom/qwen-temp-icon",
      "custom/qwen-temp"
    ]
  },
  "custom/qwen-temp": {
    "exec": "tail -F ~/.config/waybar/feeds/temp.json 2>/dev/null",
    "format": "{}",
    "return-type": "json",
    "justify": "center",
    "align": 0.5
  },
  "custom/qwen-asus-icon": {
    "exec": "~/.config/waybar/scripts/sysmon/icon.sh asus",
    "interval": "once",
    "format": "{}",
    "return-type": "json"
  },
  "group/qwen-asus": {
    "orientation": "horizontal",
    "modules": [
      "custom/qwen-asus-icon",
      "custom/qwen-asus"
    ]
  },
  "custom/qwen-asus": {
    "exec": "cat ~/.config/waybar/feeds/asus.json 2>/dev/null",
    "interval": 2,
    "format": "{}",
    "return-type": "json",
    "justify": "center",
    "align": 0.5,
    "on-click": "asusctl profile next && pkill -SIGRTMIN+10 waybar",
    "signal": 10
  }
}
