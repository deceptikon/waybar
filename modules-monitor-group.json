{
  "network#qwi": {
    "format": "   ",

    "tooltip-format": "{ifname} via {gwaddr} 󰊗",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) ",
    "tooltip-format-ethernet": "{ifname} ",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 5,
    "min-length": 5,
    "format-icons": [
      "\udb80\udf5f",
      "\udb80\udf62",
      "\udb80\udf65",
      "\udb80\udf68",
      "\udb80\udf6b",
      "\udb80\udf6e"
    ]
  },
  "group/qwen-network": {
    "orientation": "horizontal",
    "modules": [
      "network#qwi",
      "custom/qwen-wifi-info"
    ]
  },
  "custom/qwen-wifi-info": {
    "exec": "~/.config/waybar/scripts/qwen-wifi-info.sh",
    "interval": 10,
    "format": "{}",
    "return-type": "json",
    "on-click": "nm-connection-editor",
    "on-right-click": "nm-applet --indicator"
  },
  "custom/sysmon_frame#gpu": {
    "exec": "~/.config/waybar/scripts/sysmon-frame.sh gpu",
    "interval": 2,
    "format": "{}",
    "return-type": "json",
    "on-click": "nvtop"
  },
  "custom/sysmon_frame#cpu": {
    "exec": "~/.config/waybar/scripts/sysmon-frame.sh cpu",
    "interval": 5,
    "format": "{}",
    "return-type": "json",
    "on-click": "htop",
    "on-right-click": "gnome-system-monitor"
  },
  "custom/sysmon_frame#ram": {
    "exec": "~/.config/waybar/scripts/sysmon-frame.sh ram",
    "interval": 5,
    "format": "{}",
    "return-type": "json",
    "on-click": "gnome-system-monitor",
    "on-right-click": "free -h"
  },
  "custom/sysmon_frame#ssd": {
    "exec": "~/.config/waybar/scripts/sysmon-frame.sh ssd",
    "interval": 5,
    "format": "{}",
    "return-type": "json",
    "on-click": "gnome-disks",
    "on-right-click": "lsblk"
  },
  "custom/sysmon_frame#temp": {
    "exec": "~/.config/waybar/scripts/sysmon-frame.sh temp",
    "interval": 3,
    "format": "{}",
    "return-type": "json"
  },
  "custom/sysmon_frame#asus": {
    "exec": "~/.config/waybar/scripts/sysmon-frame.sh asus",
    "interval": 5,
    "format": "{}",
    "return-type": "json",
    "on-click": "asusctl profile next && pkill -SIGRTMIN+10 waybar",
    "signal": 10
  }
}
