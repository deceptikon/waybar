{
  "custom/ddc": {
    "exec": "~/.config/waybar/scripts/utils/ddc.sh combo get",
    "format": "{}",
    "return-type": "json",
    "on-scroll-up": "~/.config/waybar/scripts/utils/ddc.sh combo up && pkill -SIGRTMIN+11 waybar",
    "on-scroll-down": "~/.config/waybar/scripts/utils/ddc.sh combo down && pkill -SIGRTMIN+11 waybar",
    "on-click": "~/.config/waybar/scripts/utils/ddc.sh combo set 50 && pkill -SIGRTMIN+11 waybar",
    "on-click-right": "~/.config/waybar/scripts/utils/ddc.sh combo set 100 && pkill -SIGRTMIN+11 waybar",
    "on-click-middle": "~/.config/waybar/scripts/utils/ddc.sh combo set 0 && pkill -SIGRTMIN+11 waybar",
    "signal": 11
  },
  "custom/keylight": {
    "exec": "~/.config/waybar/scripts/utils/keylight/kbd_status_json.sh",
    "return-type": "json",
    "format": "{}",
    "on-click": "~/.config/waybar/scripts/utils/keylight/toggler.sh",
    "signal": 8
  },
  "custom/mic": {
    "exec": "~/.config/waybar/scripts/utils/mic-status.sh",
    "return-type": "json",
    "format": "{}",
    "on-click": "~/.config/waybar/scripts/utils/mic-toggle.sh",
    "signal": 13
  },
  "group/audio": {
    "orientation": "horizontal",
    "modules": ["custom/mic", "pulseaudio", "pulseaudio/slider"]
  },
  "group/bright": {
    "orientation": "horizontal",
    "modules": ["backlight", "backlight/slider"]
  },
  "group/bright-external": {
    "orientation": "horizontal",
    "modules": ["backlight", "custom/ddc"]
  },
  "pulseaudio": {
    "format": " {icon}",
    "format-muted": " \ueb24",
    "format-icons": {
      "alsa_output.pci-0000_00_1f.3.analog-stereo": "\ue32d",
      "alsa_output.pci-0000_00_1f.3.analog-stereo-muted": "\ueee8\ue32d",
      "headphone": "\uf025",
      "hands-free": "\uf590",
      "headset": "\uf590",
      "phone": "\uf095",
      "phone-muted": "\ued17",
      "portable": "\uf095",
      "car": "\uf1b9",
      "default": ["\uf026", "\uf027", "\uf028"]
    },
    "on-click": "amixer -q sset Master toggle",
    "scroll-step": 1,
    "on-right-click": "pavucontrol"
  },
  "pulseaudio/slider": {
    "min": 0,
    "max": 90,
    "orientation": "horizontal",
    "format": "{}"
  },
  "backlight": {
    "format": " \udb80\udcdf"
  },
  "backlight/slider": {
    "min": 9,
    "max": 100,
    "orientation": "horizontal",
    "device": "intel_backlight"
  },
  "battery": {
    "bat": "BAT0",
    "interval": 20,
    "full-at": 90,
    "states": {
      "good": 40,
      "warning": 30,
      "critical": 15,
      "critical-blink": 10
    },
    "design-capacity": false,
    "format-time": "{H}:{M}",
    "format-good": " {icon}<small> {capacity}%</small>",
    "format-warning": " {icon} <small>{capacity}%</small>",
    "format-critical": " {icon} <small>{capacity}%</small> ",
    "format-critical-blink": " {icon}<small> {capacity}% LOW CHARGE! (off in {time})</small> ",
    "format": "{icon}",
    "format-charging": "\uf1e6",
    "format-icons": {
      "default": [
        "\udb80\udc8e",
        "\udb80\udc7a",
        "\udb80\udc7b",
        "\udb80\udc7c",
        "\udb80\udc7d",
        "\udb80\udc7e",
        "\udb80\udc7f",
        "\udb80\udc80",
        "\udb80\udc81",
        "\udb80\udc82",
        "\udb80\udc79"
      ],
      "charging": [
        "\udb82\udc9f",
        "\udb82\udc9c",
        "\udb80\udc86",
        "\udb80\udc87",
        "\udb80\udc88",
        "\udb82\udc9d",
        "\udb80\udc89",
        "\udb82\udc9e",
        "\udb80\udc8a",
        "\udb80\udc8b",
        "\udb80\udc85"
      ]
    },
    "tooltip-format": "Time remaining: {time}\nCycles: {cycles}\nPower draw: {power}W",
    "tooltip-format-charging": "Time to full: {time}\nCycles: {cycles}\nPower draw: {power}W"
  },
  "bluetooth": {
    "format": " {icon} ",
    "format-icons": {
      "enabled": "\uf293",
      "disabled": "\udb80\udcb2"
    },
    "format-connected": "\uf294",
    "format-connected-battery": "\uf294<sub>{device_battery_percentage}%</sub>",
    "menu": "on-click",
    "menu-file": "~/.config/waybar/feeds/bt-menu.xml",
    "menu-actions": {
      "toggle": "~/.config/waybar/scripts/utils/bt-toggle.sh",
      "manager": "blueman-manager"
    },
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%"
  },
  "custom/wifi": {
    "exec": "~/.config/waybar/scripts/utils/wifi-indicator.sh",
    "return-type": "json",
    "format": "{}",
    "on-click": "~/.config/waybar/scripts/utils/wifi-toggle.sh",
    "on-click-right": "nm-connection-editor",
    "interval": 30,
    "signal": 12
  },
  "custom/powerbtn": {
    "format" : "⏻ ",
    "tooltip": false,
        "menu": "on-click",
        "menu-file": "~/.config/waybar/feeds/powermenu.xml",
        "menu-actions": {
            "shutdown": "shutdown",
            "reboot": "reboot",
            "suspend": "systemctl suspend",
            "hibernate": "systemctl hibernate"
        }
  }
}
