{
  "network#qwi": {
    "format": "  ",
    "tooltip-format": "{ifname} via {gwaddr} 󰊗",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) ",
    "tooltip-format-ethernet": "{ifname} ",
    "tooltip-format-disconnected": "Disconnected",
    "format-icons": [
      "\udb80\udf5f",
      "\udb80\udf62",
      "\udb80\udf65",
      "\udb80\udf68",
      "\udb80\udf6b",
      "\udb80\udf6e"
    ]
  },
  "group/qwen-network": {
    "orientation": "horizontal",
    "modules": [
      "network#qwi",
      "custom/qwen-wifi-info"
    ]
  },
  "custom/qwen-wifi-info": {
    "exec": "~/.config/waybar/scripts/network/wifi-info.sh",
    "interval": 2,
    "format": "{}",
    "return-type": "json",
    "justify": "center",
    "align": 0.5,
    "on-click": "nm-connection-editor",
    "on-right-click": "nm-applet --indicator"
  },

  "custom/qwen-gpu-icon": { "format": " 󰢮 " },
  "group/qwen-gpu": {
    "orientation": "horizontal",
    "modules": ["custom/qwen-gpu-icon", "custom/qwen-gpu"]
  },
  "custom/qwen-gpu": {
    "exec": "tail -F ~/.config/waybar/feeds/gpu.json",
    "format": "{}",
    "return-type": "json",
    "justify": "center",
    "align": 0.5,
    "on-click": "gpustat",
    "on-right-click": "nvtop"
  },

  "custom/qwen-cpu-icon": { "format": " 󰍛 " },
  "group/qwen-cpu": {
    "orientation": "horizontal",
    "modules": ["custom/qwen-cpu-icon", "custom/qwen-cpu"]
  },
  "custom/qwen-cpu": {
    "exec": "tail -F ~/.config/waybar/feeds/cpu.json",
    "format": "{}",
    "return-type": "json",
    "justify": "center",
    "align": 0.5,
    "on-click": "htop",
    "on-right-click": "gnome-system-monitor"
  },

  "custom/qwen-ram-icon": { "format": "  " },
  "group/qwen-ram": {
    "orientation": "horizontal",
    "modules": ["custom/qwen-ram-icon", "custom/qwen-ram"]
  },
  "custom/qwen-ram": {
    "exec": "tail -F ~/.config/waybar/feeds/ram.json",
    "format": "{}",
    "return-type": "json",
    "justify": "center",
    "align": 0.5,
    "on-click": "gnome-system-monitor",
    "on-right-click": "free -h"
  },

  "custom/qwen-ssd-icon": { "format": " 󰋊 " },
  "group/qwen-ssd": {
    "orientation": "horizontal",
    "modules": ["custom/qwen-ssd-icon", "custom/qwen-ssd"]
  },
  "custom/qwen-ssd": {
    "exec": "tail -F ~/.config/waybar/feeds/ssd.json",
    "format": "{}",
    "return-type": "json",
    "justify": "center",
    "align": 0.5,
    "on-click": "gnome-disks",
    "on-right-click": "lsblk"
  },

  "custom/qwen-netfan-icon": { "format": " 󰛳 " },
  "group/qwen-netfan": {
    "orientation": "horizontal",
    "modules": ["custom/qwen-netfan-icon", "custom/qwen-netfan"]
  },
  "custom/qwen-netfan": {
    "exec": "tail -F ~/.config/waybar/feeds/netfan.json",
    "format": "{}",
    "return-type": "json",
    "justify": "center",
    "align": 0.5,
    "on-click": "nm-connection-editor",
    "on-right-click": "nm-connection-editor"
  },

  "custom/compact-gpu": {
    "exec": "tail -F ~/.config/waybar/feeds/compact-gpu.json",
    "format": "{}",
    "return-type": "json",
    "justify": "center",
    "align": 0.5
  },
  "custom/compact-cpu": {
    "exec": "tail -F ~/.config/waybar/feeds/compact-cpu.json",
    "format": "{}",
    "return-type": "json",
    "justify": "center",
    "align": 0.5
  },
  "custom/compact-ram": {
    "exec": "tail -F ~/.config/waybar/feeds/compact-ram.json",
    "format": "{}",
    "return-type": "json",
    "justify": "center",
    "align": 0.5
  },
  "custom/compact-ssd": {
    "exec": "tail -F ~/.config/waybar/feeds/compact-ssd.json",
    "format": "{}",
    "return-type": "json",
    "justify": "center",
    "align": 0.5
  },
  "custom/compact-netfan": {
    "exec": "tail -F ~/.config/waybar/feeds/compact-netfan.json",
    "format": "{}",
    "return-type": "json",
    "justify": "center",
    "align": 0.5
  },

  "custom/qwen-asus-icon": { "format": "  " },
  "group/qwen-asus": {
    "orientation": "horizontal",
    "modules": ["custom/qwen-asus-icon", "custom/qwen-asus"]
  },
  "custom/qwen-asus": {
    "exec": "echo '{\"text\":\"\",\"class\":\"good\"}'",
    "interval": 3600,
    "format": "{}",
    "return-type": "json",
    "justify": "center",
    "align": 0.5,
    "tooltip": "ASUS/profile module stubbed (out of sysmon scope)"
  }
}
