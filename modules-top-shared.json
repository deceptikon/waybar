{
  "group/titlebox-row": {
    "orientation": "horizontal",
    "modules": [
      "custom/ws-color",
      "sway/window",
      "sway/scratchpad",
      "privacy"
    ]
  },
  "custom/ws-color": {
    "exec": "(swaymsg -t get_workspaces 2>/dev/null | jq -c '.[] | select(.focused==true) | {text: (.num | tostring), class: (\"ws\" + (.num | tostring)), tooltip: (\"Workspace \" + (.num | tostring))}'; stdbuf -oL swaymsg -t subscribe '[\"workspace\"]' 2>/dev/null | jq --unbuffered -c 'if .change == \"focus\" then {text: (.current.num | tostring), class: (\"ws\" + (.current.num | tostring)), tooltip: (\"Workspace \" + (.current.num | tostring))} else empty end')",
    "format": "{}",
    "return-type": "json",
    "restart-interval": -1,
    "tooltip": true
  },
  "clock#date": {
    "format": "<span text_transform=\"uppercase\">{:%A, %d %B %Y}</span>",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "clock#time": {
    "format": "{:%H:%M}",
    "tooltip": false
  },
  "sway/workspaces": {
    "disable-scroll": false,
    "enable-bar-scroll": true,
    "disable-auto-back-and-forth": true,
    "smooth-scrolling-threshold": 20,
    "disable-scroll-wraparound": false,
    "format": ". {icon} <sub>{value}</sub> .",
    "format-icons": {
      "1": "\uf120",
      "2": "\uf268",
      "3": "\uf121",
      "4": "\uf1bc",
      "5": "\uf075",
      "focused": "\uf192",
      "urgent": "\uf06a",
      "active": "\uf192",
      "default": "\uf111"
    },
    "sort-by-number": true,
    "persistent_workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },
  "sway/scratchpad": {
    "format": "{icon} {count}",
    "show-empty": false,
    "format-icons": [
      "",
      "\uf2d2"
    ],
    "tooltip": true,
    "tooltip-format": "{app}: {title}"
  },
  "sway/window": {
    "format": "\uf17c [{title}] {app_id}",
    "max-length": "",
    "all-outputs": true,
    "offscreen-css": true,
    "offscreen-css-text": "NO FOCUS",
    "icon-size": 16,
    "rewrite": {
      "(.*) Mozilla Firefox": "$1 \ud83c\udf0e",
      "(.*) VSCodium": "$1 \udb82\ude1e"
    }
  }
}
