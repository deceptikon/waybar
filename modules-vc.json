{
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": " <sup>󰒳</sup>",
      "deactivated": "󰾪 <sup>󰒲</sup>"
    }
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "",
      "performance": "",
      "balanced": " ",
      "power-saver": "󱤅"
    }
  },
  "custom/dunst": {
    "exec": "~/.config/waybar/scripts/utils/dunst.sh refresh",
    "return-type": "json",
    "interval": 1000,
    "format": "{}",
    "on-click": "~/.config/waybar/scripts/utils/dunst.sh",
    "signal": 9
  },
  "custom/recorder": {
    "format": "{}",
    "interval": "once",
    "return-type": "json",
    "exec": "echo \"$(pgrep -x wf-recorder > /tmp/wf_pgrep.log && echo '{\"text\":\"󰨜 <sup>󰑊</sup>\",\"class\":\"recording\"}' || echo '{\"text\":\"󰨜 <sup></sup>\",\"class\":\"stopped\"}')\"",
    "signal": 8,
    "on-click": "~/.config/waybar/scripts/utils/capturer.sh",
    "on-right-click": "kill $(pgrep -x wf-recorder)",
    "tooltip": false
  },
  "custom/fnlock": {
    "exec": "~/.config/waybar/scripts/utils/fn-lock.sh refresh",
    "return-type": "json",
    "signal": 10,
    "on-click": "/usr/local/bin/toggle_fn_lock.sh"
  },
  "custom/ext-display": {
    "exec": "~/.config/waybar/scripts/utils/ext-display.sh refresh",
    "return-type": "json",
    "format": "{}",
    "interval": 1,
    "on-click": "~/.config/waybar/scripts/utils/ext-display.sh",
    "signal": 11
  },
  "custom/llama": {
    "exec": "~/.config/waybar/scripts/utils/llama-server.sh",
    "return-type": "json",
    "format": "{}",
    "interval": 5,
    "signal": 22,
    "menu": "on-click",
    "menu-file": "~/.config/waybar/feeds/llama-menu.xml",
    "menu-actions": {
      "start": "~/.config/waybar/scripts/utils/llama-server.sh start",
      "stop": "~/.config/waybar/scripts/utils/llama-server.sh stop",
      "restart": "~/.config/waybar/scripts/utils/llama-server.sh restart"
    }
  },
  "custom/ollama": {
    "exec": "if curl -s http://localhost:11111/api/tags > /tmp/llama_curl.log 2>&1; then models=$(OLLAMA_HOST=localhost:11111 ollama ps | awk 'NR>1 {print $1}' | paste -sd ' ' -); if [ -n \"$models\" ]; then jq -cn --arg m \"$models\" '{text:(\"󱚣 \" + $m),tooltip:(\"Running: \" + $m),class:\"on\"}'; else jq -cn '{text:\"󱚣 UP\",tooltip:\"Ollama is running (no models loaded)\",class:\"on\"}'; fi; else jq -cn '{text:\"󱚣 DOWN\",tooltip:\"Ollama is not running\",class:\"off\"}'; fi",
    "interval": 5,
    "format": "{}",
    "return-type": "json"
  },
  "custom/profile": {
    "exec": "~/.config/waybar/scripts/utils/profile-indicator.sh",
    "return-type": "json",
    "format": "{}",
    "interval": 2,
    "on-click": "asusctl profile next"
  },
  "custom/powerbtn": {
    "exec": "uptime -p | sed 's/up //' | awk '{d=0;h=0;m=0; if($0~/(day)/){match($0,/([0-9]+)[[:space:]]*day/,a);d=a[1]+0} if($0~/(hour)/){match($0,/([0-9]+)[[:space:]]*hour/,a);h=a[1]+0} if($0~/(min)/){match($0,/([0-9]+)[[:space:]]*min/,a);m=a[1]+0} t=d*24*60+h*60+m; printf \" <sub>%dh </sub> ⏻ <sub> %dm</sub>\", int(t/60), t%60}'",
    "interval": 60,
    "format": "{}",
    "tooltip": false,
    "menu": "on-click",
    "menu-file": "~/.config/waybar/feeds/powermenu.xml",
    "menu-actions": {
      "shutdown": "shutdown",
      "reboot": "reboot",
      "suspend": "systemctl suspend",
      "hibernate": "systemctl hibernate"
    }
  }
}
