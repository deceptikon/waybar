# ~/.config/waybar/sysmon.env  (and/or repo root)
SYSMON_FEEDS="${HOME}/.config/waybar/feeds"
SYSMON_LOG_DIR="${HOME}/.config/waybar/logs"
SYSMON_POLL_SLEEP=2
SYSMON_DISK_DEV=nvme0n1
SYSMON_NET_IF=wlp98s0
